{
  "expo": {
    "name": "TaskHero",
    "slug": "taskhero",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/taskhero.png",
    "scheme": "taskhero",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/taskhero.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.taskhero.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/taskhero.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.taskhero.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/taskhero.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
