{
  "name": "taskhero",
  "version": "1.0.0",
  "description": "TaskHero - Gamified mission platform for families",
  "private": true,
  "workspaces": {
    "packages": [
      "backend",
      "mobile",
      "packages/*"
    ],
    "nohoist": [
      "mobile/**"
    ]
  },
  "scripts": {
    "backend:dev": "npm run dev --workspace=backend",
    "backend:build": "npm run build --workspace=backend",
    "backend:start": "npm run start:prod --workspace=backend",
    "backend:test": "npm run test --workspace=backend",
    "mobile:start": "npm run start --workspace=mobile",
    "mobile:ios": "npm run ios --workspace=mobile",
    "mobile:android": "npm run android --workspace=mobile",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "db:studio": "npm run db:studio --workspace=backend",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "clean": "rm -rf node_modules backend/node_modules mobile/node_modules packages/*/node_modules"
  },
  "keywords": [
    "taskhero",
    "gamification",
    "family",
    "missions",
    "children",
    "parenting"
  ],
  "author": "TaskHero Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.56.2"
  }
}
